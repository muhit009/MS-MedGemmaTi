# Application
APP_NAME=MedGemma Clinical Suite API
APP_VERSION=1.0.0
DEBUG=True

# CORS - Add your frontend URLs
CORS_ORIGINS=["*"]

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MedGemma AI Service (configure when ready)
MEDGEMMA_API_URL=http://localhost:8080/generate
MEDGEMMA_API_KEY=your-medgemma-api-key

# RunPod Serverless (takes priority over local model server when set)
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
RUNPOD_API_KEY=your-runpod-api-key

# Storage
STORAGE_BUCKET=medical-images